{
  "name": "@withkey/web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/copy-ffmpeg.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit",
    "test:ci": "vitest run --project unit --reporter=dot",
    "test:integration": "vitest run --project integration",
    "test:integration:cleanup": "node scripts/test/integration-cleanup.mjs",
    "test:integration:reenable-trigger": "node scripts/test/integration-reenable-trigger.mjs",
    "test:e2e": "playwright test --project=e2e",
    "test:e2e:ui": "playwright test --project=e2e --ui",
    "test:a11y": "playwright test --project=a11y",
    "test:watch": "vitest",
    "login:link": "node scripts/dev-login-link.mjs",
    "seed:action-log": "node scripts/dev-seed-action-log.mjs",
    "icons:pwa": "node scripts/generate-pwa-icons.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^3.9.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "@withkey/domain": "workspace:*",
    "canvas-confetti": "^1.9.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "exif-reader": "^2.0.3",
    "ffmpeg-static": "^5.3.0",
    "heic2any": "0.0.4",
    "idb": "^8.0.3",
    "lucide-react": "^1.11.0",
    "next": "16.2.x",
    "next-themes": "^0.4.6",
    "openai": "^4.77.0",
    "react": "19.2.4",
    "react-day-picker": "^10.0.0",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.54.2",
    "server-only": "^0.0.1",
    "shadcn": "^4.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^4.3.4",
    "axe-core": "^4.11.4",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.x",
    "jsdom": "^25.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^2.1.8"
  }
}
