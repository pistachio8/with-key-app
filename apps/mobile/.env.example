# apps/mobile 환경 변수 (EVAL-0012 · ADR-0034)
#
# EXPO_PUBLIC_* 만 허용 — 앱 번들에 그대로 포함되는 공개 값이다.
# sb_secret_* · OPENAI_API_KEY · VAPID_PRIVATE_KEY 등 서버 전용 키는
# 절대 이 파일/이 앱에 넣지 않는다 (03-rn-migration-rules §6·§10).
# 레거시 명칭(*_ANON_KEY / *_SERVICE_ROLE_KEY) 금지 — supabase-keys 규칙.

# Supabase — apps/web 의 NEXT_PUBLIC_SUPABASE_* 와 같은 값 (POC 단일 프로젝트)
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# BFF(Bearer) base URL override (ADR-0036 · EVAL-0016) — 선택값.
# 비우면 앱 variant 의 universal link 도메인(https://<universalLinkDomain>)을 BFF 호스트로 사용.
# 로컬 web dev 서버를 BFF 로 쓸 때만 지정 (예: http://localhost:3000).
EXPO_PUBLIC_BFF_BASE_URL=

# Kakao 네이티브 앱 키 (ADR-0034 결정 1) — 공개 가능 키.
# 카카오 콘솔에서 Android keyhash · iOS bundle id 로 사용처가 제한된다.
# 비어 있으면: config plugin 미포함 + 런타임 Kakao 로그인 비활성 → magic link 만 동작.
# 값을 넣거나 바꾸면 dev build 재생성(prebuild) 필요.
EXPO_PUBLIC_KAKAO_NATIVE_KEY=

# dev-login 모드 (디버깅용 카카오 우회, spec 2026-06-19 §5.4) — dev variant 전용.
# app.config 가 variant==='dev' 일 때만 extra 에 주입하므로 prod/staging 번들엔 미포함.
# DEV_LOGIN_URL: dev web 배포의 develop 안정 alias (per-deploy 해시 URL 아님).
# VERCEL_BYPASS: Vercel Protection Bypass for Automation 토큰 — Preview 인증 벽 통과(겸 dev 시크릿).
EXPO_PUBLIC_DEV_LOGIN_URL=
EXPO_PUBLIC_VERCEL_BYPASS=
