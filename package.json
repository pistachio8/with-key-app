{
  "name": "with-key",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "packageManager": "pnpm@10.7.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --ignore-pattern '.claude/skills/' --ignore-pattern '.agents/'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit",
    "test:ci": "vitest run --project unit --reporter=dot",
    "test:integration": "vitest run --project integration",
    "test:e2e": "playwright test --project=e2e",
    "test:e2e:ui": "playwright test --project=e2e --ui",
    "test:a11y": "playwright test --project=a11y",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:push": "supabase db push --linked",
    "db:diff": "supabase db diff --linked",
    "db:types": "supabase gen types typescript --linked > src/types/supabase.ts",
    "login:link": "node scripts/dev-login-link.mjs",
    "seed:action-log": "node scripts/dev-seed-action-log.mjs",
    "validate:docs": "node scripts/validate-doc-paths.mjs",
    "check:spec-required": "node scripts/check-spec-required.mjs",
    "new": "node scripts/new-doc.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^3.9.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "heic2any": "0.0.4",
    "lucide-react": "^1.11.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "openai": "^4.77.0",
    "react": "19.2.4",
    "react-day-picker": "^10.0.0",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.54.2",
    "server-only": "^0.0.1",
    "shadcn": "^4.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^4.3.4",
    "axe-core": "^4.11.4",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^17.0.4",
    "prettier": "^3.4.2",
    "supabase": "^2.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  }
}
