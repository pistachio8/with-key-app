{
  "name": "with-key",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "packageManager": "pnpm@10.7.0",
  "scripts": {
    "dev": "pnpm --filter @withkey/web dev",
    "build": "pnpm --filter @withkey/web build",
    "start": "pnpm --filter @withkey/web start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:ci": "pnpm --filter @withkey/web test:ci",
    "test:integration": "pnpm --filter @withkey/web test:integration",
    "test:integration:cleanup": "pnpm --filter @withkey/web test:integration:cleanup",
    "test:integration:reenable-trigger": "pnpm --filter @withkey/web test:integration:reenable-trigger",
    "test:e2e": "pnpm --filter @withkey/web test:e2e",
    "test:e2e:ui": "pnpm --filter @withkey/web test:e2e:ui",
    "test:a11y": "pnpm --filter @withkey/web test:a11y",
    "test:watch": "pnpm --filter @withkey/web test:watch",
    "login:link": "pnpm --filter @withkey/web login:link",
    "seed:action-log": "pnpm --filter @withkey/web seed:action-log",
    "icons:pwa": "pnpm --filter @withkey/web icons:pwa",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:push": "supabase db push --linked",
    "db:diff": "supabase db diff --linked",
    "db:types": "supabase gen types typescript --linked > apps/web/src/types/supabase.ts",
    "release:notify": "node scripts/post-release-note.mjs",
    "validate:docs": "node scripts/validate-doc-paths.mjs",
    "check:spec-required": "node scripts/check-spec-required.mjs",
    "new": "node scripts/new-doc.mjs",
    "harness:check": "node scripts/harness-check.mjs",
    "harness:drift": "node scripts/harness-drift.mjs",
    "harness:summarize-diff": "node scripts/harness-summarize-diff.mjs",
    "harness:context": "node scripts/harness-context.mjs",
    "harness:goal": "node scripts/harness-goal.mjs",
    "harness:test": "node --test scripts/harness-lib.spec.mjs",
    "harness:verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm harness:check && pnpm harness:test",
    "prepare": "husky"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.4.2",
    "supabase": "^2.2.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  }
}
