# with-key pre-commit hook — 저마찰 ergonomics
#
# 동작:
# - lint-staged가 staged 파일에만 prettier --write 실행
# - ESLint는 모노레포 전환(EVAL-0010) 후 CI `pnpm -r lint`로 일원화 — 루트 eslint config 부재로 pre-commit 제외
# - 자동 포맷만 — commit 차단 거의 없음
# - lint / typecheck / test / spec-check은 CI에 위임
#
# 우회 (급할 때 또는 hook 자체가 버그일 때):
#   WITHKEY_HOOKS=skip git commit ...   # with-key 합의된 우회 신호
#   git commit --no-verify ...          # 표준 Git 우회
#
# Hook이 commit을 차단하거나 1초 이상 느려지면 그 자체가 버그 — issue로 보고.

[ "$WITHKEY_HOOKS" = "skip" ] && exit 0

pnpm lint-staged
