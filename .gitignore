# Dependencies
/node_modules
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Caches
.cache/
.turbo
*.tsbuildinfo

# Next.js
/.next/
/out/
/build
next-env.d.ts

# ffmpeg-static 바이너리 — 빌드 시 symlink 밖으로 복사 (scripts/copy-ffmpeg.mjs)
/bin/ffmpeg

# Testing
/coverage

# Monorepo — apps/web build/test artifacts (위 root-anchored 패턴을 apps/web 으로 확장)
/apps/web/.next/
/apps/web/out/
/apps/web/bin/ffmpeg
/apps/web/coverage/
/apps/web/test-results/
/apps/web/playwright-report/
/apps/web/tests/e2e/.auth/

# Harness — /goal 파생 뷰(pnpm harness:goal --write). SoT 는 task 파일이라 버전관리 안 함.
evals/tasks/*.goal.md

# Vercel
.vercel

# Env (local only — never commit; use .env.example as template)
.env
.env.local
.env.*.local
.envrc

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
yarn.lock

# Tooling
.DS_Store
*.pem
*.bak

# Supabase CLI link-state (per-machine)
supabase/.temp/
supabase/.branches/

# Playwright
/test-results/
/playwright-report/
/tests/e2e/.auth/

# Personal AI assistant workspace
# Keep the directory open so we can whitelist team-shared subtrees below.
/.claude/*
!/.claude/rules/
!/.claude/commands/
!/.claude/skills/
!/.claude/agents/
!/.claude/settings.json
!/.claude/project-log-policy.md
# Generated evaluation workspaces under tracked Claude skills are local artifacts.
/.claude/skills/*-workspace/
# Personal subtrees under .claude/rules/ (if any) should be re-ignored here.
.cursor/
.codex/

# Personal journal (Ian's dev log — not for team)
docs/JOURNAL.md

# QA triage snapshot (local — Slack #qa dogfood, not for team)
docs/QA_TRIAGE.md

# Vendored skills (.agents/skills/) are external copies (npm-package-like), not our code.
# Track only the manifest (skills-lock.json, repo root); keep external skill files local.
# Rationale: no in-repo vendoring tool to verify/reinstall, so tracking files just
# accumulates drift (ECC auto-drops, ghost lock pins). Manifest = source of truth. ADR-0031.
/.agents/skills/*

# Repo-owned Codex adapters for with-key review flow. These mirror tracked
# Claude-specific adapters under .claude/.
!/.agents/skills/withkey-review/
!/.agents/skills/withkey-review/**
!/.agents/skills/withkey-migration-reviewer/
!/.agents/skills/withkey-migration-reviewer/**
!/.agents/skills/withkey-backend-reviewer/
!/.agents/skills/withkey-backend-reviewer/**
!/.agents/skills/withkey-frontend-reviewer/
!/.agents/skills/withkey-frontend-reviewer/**

.superpowers/
