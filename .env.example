# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_CODENAME=with-key

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # 서버 전용 — 절대 NEXT_PUBLIC_ 접두 금지

# --- OpenAI ---
OPENAI_API_KEY=                      # 서버 전용
OPENAI_MODEL=gpt-4o-mini
AI_MONTHLY_BUDGET_KRW=50000          # 킥오프 확정값

# --- Kakao OAuth (옵션) ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# --- Web Push (VAPID) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=                   # 서버 전용
VAPID_SUBJECT=mailto:ian@example.com

# --- Sentry (옵션 — 킥오프 기본 off) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Feature Flags ---
FEATURE_ALIMTALK=false
