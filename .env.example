# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_CODENAME=with-key

# --- Supabase ---
# Dashboard → Settings → API → Project URL (경로 없이 base URL만)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...                                # 서버 전용 — sb_secret_* 형식 (레거시 SERVICE_ROLE_KEY 대체)
#
# GitHub Actions 는 동일한 값을 다음 secret 이름으로 저장한다(POC 단일 프로젝트):
#   SUPABASE_URL               = NEXT_PUBLIC_SUPABASE_URL 과 동일
#   SUPABASE_PUBLISHABLE_KEY   = NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY 와 동일
#   SUPABASE_SECRET_KEY        = SUPABASE_SECRET_KEY 와 동일
#   SUPABASE_ACCESS_TOKEN      = https://supabase.com/dashboard/account/tokens 에서 발급
#   SUPABASE_DB_PASSWORD       = 대시보드 → Database → Connection password
# ci.yml 의 각 job env 블록이 이 secret 들을 NEXT_PUBLIC_* 이름으로 매핑한다.

# --- OpenAI ---
OPENAI_API_KEY=                      # 서버 전용. 비어있으면 generateDiary 가 항상 템플릿 폴백.
OPENAI_MODEL=gpt-4o-mini
AI_MONTHLY_BUDGET_KRW=50000          # 킥오프 확정값
#
# AI 비용 스코프 분리 (D-014):
#   - ai_cost_log 테이블은 PK=(month, scope). scope ∈ {'prod','test'} 로 누적 격리.
#   - currentScope() 판정은 VERCEL_ENV === 'production' → 'prod', 그 외 → 'test'.
#     로컬(VERCEL_ENV undefined)과 Preview(VERCEL_ENV='preview')는 모두 'test' 로 분류.
#   - Vercel Production 환경에만 OPENAI_API_KEY 를 세팅해야 prod 누적이 의미를 가짐.
#   - Preview 에서도 실 AI 를 호출하려면 Preview env 에 별도 키 등록. test scope 로 누적됨.

# --- Kakao OAuth (옵션) ---
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# --- KakaoPay 송금 링크 (POC · host allowlist 강제) ---
# 허용: qr.kakaopay.com · pay.kakao.com · link.kakao.com
NEXT_PUBLIC_KAKAOPAY_SEND_URL=

# --- Web Push (VAPID) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=                   # 서버 전용
VAPID_SUBJECT=mailto:wjaden0107@gmail.com

# --- Cron (Vercel) ---
# openssl rand -hex 32 로 생성. Vercel Cron 이 호출 시 Authorization: Bearer $CRON_SECRET
# 헤더를 같이 보낸다. /api/cron/deadline-push 가 이 값으로 요청을 게이트한다.
# Vercel (Production + Preview) env 에 동일 값 등록.
CRON_SECRET=

# --- Sentry (옵션 — 킥오프 기본 off) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Feature Flags ---
FEATURE_ALIMTALK=false

# --- Dev-only ---
# 개인 개발용. `pnpm login:link` 가 SMTP rate limit 을 우회해 magic link URL 을
# 출력할 때 기본으로 쓰는 이메일. 팀원마다 본인 테스트 계정을 넣는다.
# 인자로 직접 넘기면 이 값을 덮어쓴다: `pnpm login:link other@example.com`
DEV_LOGIN_EMAIL=
